{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32F407 Debug",
            "type": "cortex-debug",
            "request": "launch",

            "cwd": "${workspaceFolder}",

            "executable": "${workspaceFolder}/build/Debug/printf.elf",

            "servertype": "openocd",

            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],

            "device": "STM32F407VGT6",

            "runToEntryPoint": "main",

            "gdbPath": "C:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            "swoConfig": {
                "enabled": true,
                "cpuFrequency": 168000000,
                "swoFrequency": 2000000,
                "source": "probe",
                "decoders": [
                    {
                        "type": "console",
                        "label": "SWO Console",
                        "port": 0,
                        "encoding": "utf8"
                    }
                ]
            }
        }
    ]
}